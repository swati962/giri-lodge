@model IEnumerable<HotelManagement.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people"></i> Hotel Customers</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Customer
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="searchPhone" class="form-label">Search by Phone</label>
                    <input type="text" class="form-control" id="searchPhone" name="searchPhone" 
                           value="@ViewData["SearchPhone"]" placeholder="Enter phone number">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary me-2">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Check-in</th>
                                <th>Check-out</th>
                                <th>Status</th>
                                <th>ID Proof</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in Model)
                            {
                                <tr>
                                    <td>@customer.Name</td>
                                    <td>@customer.Phone</td>
                                    <td>@customer.CheckInDate.ToString("MMM dd, yyyy")</td>
                                    <td>@customer.CheckOutDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (customer.IsCheckedOut)
                                        {
                                            <span class="badge bg-secondary">Checked Out</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(customer.IdProofUrl))
                                        {
                                            <a href="@customer.IdProofUrl" target="_blank" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-file-earmark"></i> View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (!customer.IsCheckedOut)
                                            {
                                                <form asp-action="Checkout" asp-route-id="@customer.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" 
                                                            onclick="return confirm('Are you sure you want to check out this customer?')">
                                                        <i class="bi bi-box-arrow-right"></i> Checkout
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="Delete" asp-route-id="@customer.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                        onclick="return confirm('Are you sure you want to delete this customer?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="mt-3 text-muted">No customers found.</p>
                    <a asp-action="Create" class="btn btn-primary">Add Your First Customer</a>
                </div>
            }
        </div>
    </div>
</div>
